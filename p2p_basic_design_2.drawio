<mxfile host="app.diagrams.net">
  <diagram name="Page-1" id="39zfOqVGr2L-zaKaUKqZ">
    <mxGraphModel dx="1287" dy="771" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="850" pageHeight="1100" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <UserObject label="" plantUmlData="{&#xa;  &quot;data&quot;: &quot;@startuml\n\nenum PeerStatus {\n  ONLINE\n  OFFLINE\n  CONNECTING\n  BLOCKED\n}\n\nclass User {\n  - userId : string\n  - username : string\n  - publicKey : string\n  + login() : bool\n  + logout() : void\n  + getUsername() : string\n}\n\nclass Peer {\n  - peerId : string\n  - ipAddress : string\n  - port : int\n  - status : PeerStatus\n  + connect() : bool\n  + disconnect() : void\n  + sendMessage(message : Message) : void\n  + getStatus() : PeerStatus\n}\n\nclass PeerManager {\n  - peers : vector&lt;Peer&gt;\n  + discoverPeers() : void\n  + addPeer(peer : Peer) : void\n  + removePeer(peerId : string) : void\n  + getAvailablePeers() : vector&lt;Peer&gt;\n}\n\nclass Connection {\n  - connectionId : string\n  - socketFd : int\n  - encrypted : bool\n  + open(peer : Peer) : bool\n  + close() : void\n  + send(data : vector&lt;byte&gt;) : void\n  + receive() : vector&lt;byte&gt;\n}\n\nclass ConnectionManager {\n  - activeConnections : map&lt;string, Connection&gt;\n  + openConnection(peer : Peer) : void\n  + closeConnection(peerId : string) : void\n  + broadcast(message : Message) : void\n}\n\nclass Message {\n  - messageId : string\n  - senderId : string\n  - receiverId : string\n  - content : string\n  - timestamp : DateTime\n  + serialize() : string\n  + deserialize(data : string) : Message\n}\n\nclass MessageService {\n  + createMessage(content : string) : Message\n  + sendMessage(peer : Peer, message : Message) : void\n  + receiveMessage() : Message\n}\n\nclass FileChunk {\n  - chunkId : string\n  - fileId : string\n  - chunkNumber : int\n  - data : vector&lt;byte&gt;\n  + getData() : vector&lt;byte&gt;\n}\n\nclass SharedFile {\n  - fileId : string\n  - fileName : string\n  - fileSize : long\n  - checksum : string\n  + splitIntoChunks() : vector&lt;FileChunk&gt;\n  + verifyChecksum() : bool\n}\n\nclass FileManager {\n  - sharedFiles : vector&lt;SharedFile&gt;\n  + shareFile(path : string) : void\n  + requestFile(fileId : string, peer : Peer) : void\n  + saveFile(file : SharedFile) : void\n}\n\nclass SecurityService {\n  + encrypt(data : vector&lt;byte&gt;) : vector&lt;byte&gt;\n  + decrypt(data : vector&lt;byte&gt;) : vector&lt;byte&gt;\n  + verifyPeer(peer : Peer) : bool\n}\n\nclass PeerApplication {\n  - currentUser : User\n  - peerManager : PeerManager\n  - connectionManager : ConnectionManager\n  - messageService : MessageService\n  - fileManager : FileManager\n  - securityService : SecurityService\n  + start() : void\n  + shutdown() : void\n}\n\nPeerApplication *-- User\nPeerApplication *-- PeerManager\nPeerApplication *-- ConnectionManager\nPeerApplication *-- MessageService\nPeerApplication *-- FileManager\nPeerApplication *-- SecurityService\n\nPeerManager o-- Peer\nPeer --&gt; PeerStatus\n\nConnectionManager o-- Connection\nConnection --&gt; Peer\n\nMessageService --&gt; Message\nMessageService --&gt; Peer\nMessageService --&gt; SecurityService\n\nFileManager o-- SharedFile\nFileManager --&gt; Peer\nFileManager --&gt; SecurityService\n\nSharedFile *-- FileChunk\n\nPeer --&gt; Message\n\n@enduml&quot;,&#xa;  &quot;format&quot;: &quot;svg&quot;&#xa;}" id="7X_5IjvBuIbbORYnlfAa-1">
          <mxCell parent="1" style="shape=image;noLabel=1;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/svg+xml,;" vertex="1">
